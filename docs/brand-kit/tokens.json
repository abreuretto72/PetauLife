{
  "$description": "auExpert Elite design tokens — W3C Design Tokens Community Group format. Importável em Figma via Tokens Studio, em Style Dictionary, ou em qualquer pipeline que consuma DTCG.",
  "$version": "1.0.0",

  "color": {
    "brand": {
      "click": {
        "value": "#8F7FA8",
        "type": "color",
        "description": "Ametista — cor de ação primária (botões, links, ícones clicáveis)"
      },
      "clickLight": {
        "value": "#A89AC2",
        "type": "color",
        "description": "Ametista clara — hover e destaques leves"
      },
      "clickDark": {
        "value": "#6B5A8A",
        "type": "color",
        "description": "Ametista escura — pressed state e gradiente inferior"
      },
      "ai": {
        "value": "#4FA89E",
        "type": "color",
        "description": "Jade — funcionalidades de IA, análises, insights (substitui o roxo/purple antigo)"
      }
    },

    "bg": {
      "primary": {
        "value": "#0D0E16",
        "type": "color",
        "description": "Background principal da tela (dark theme)"
      },
      "card": {
        "value": "#161826",
        "type": "color",
        "description": "Cards, drawers, elementos elevados"
      },
      "deep": {
        "value": "#08090F",
        "type": "color",
        "description": "Áreas recuadas, modal backdrop"
      }
    },

    "text": {
      "primary": {
        "value": "#F0EDF5",
        "type": "color",
        "description": "Títulos e texto principal (máximo contraste sobre bg)"
      },
      "secondary": {
        "value": "#A89FB5",
        "type": "color",
        "description": "Texto secundário, descrições, valores"
      },
      "dim": {
        "value": "#6B6478",
        "type": "color",
        "description": "Labels, captions, hints, placeholders"
      }
    },

    "semantic": {
      "success": {
        "value": "#7FA886",
        "type": "color",
        "description": "Sucesso, saúde OK, vacinas em dia"
      },
      "warning": {
        "value": "#D4A574",
        "type": "color",
        "description": "Aviso moderado, atenção, gamificação/conquistas"
      },
      "danger": {
        "value": "#C2645E",
        "type": "color",
        "description": "Erro, perigo, lixeira, vacinas vencidas"
      }
    },

    "structure": {
      "border": {
        "value": "#2A2D3E",
        "type": "color",
        "description": "Bordas padrão de inputs, cards, divisores"
      },
      "borderLight": {
        "value": "#3A3D50",
        "type": "color",
        "description": "Bordas internas sutis, hover de cards"
      }
    }
  },

  "typography": {
    "fontFamily": {
      "display": {
        "value": "Playfair Display",
        "type": "fontFamily",
        "description": "Logo + títulos literários curtos. Único lugar permitido de itálico é o `au` do logo."
      },
      "body": {
        "value": "Inter",
        "type": "fontFamily",
        "description": "UI, labels, botões, texto corrido, narração de IA"
      },
      "mono": {
        "value": "JetBrains Mono",
        "type": "fontFamily",
        "description": "Scores numéricos, timestamps, confidence, IDs"
      }
    },

    "fontWeight": {
      "light":    { "value": 300, "type": "fontWeight" },
      "regular":  { "value": 400, "type": "fontWeight" },
      "medium":   { "value": 500, "type": "fontWeight" },
      "semibold": { "value": 600, "type": "fontWeight" },
      "bold":     { "value": 700, "type": "fontWeight" }
    }
  },

  "radius": {
    "sm":    { "value": "8px",  "type": "dimension" },
    "md":    { "value": "10px", "type": "dimension" },
    "lg":    { "value": "12px", "type": "dimension" },
    "xl":    { "value": "14px", "type": "dimension" },
    "xxl":   { "value": "18px", "type": "dimension" },
    "card":  { "value": "22px", "type": "dimension" },
    "modal": { "value": "26px", "type": "dimension" }
  },

  "spacing": {
    "xs":  { "value": "4px",  "type": "dimension" },
    "sm":  { "value": "8px",  "type": "dimension" },
    "md":  { "value": "16px", "type": "dimension" },
    "lg":  { "value": "24px", "type": "dimension" },
    "xl":  { "value": "32px", "type": "dimension" },
    "xxl": { "value": "40px", "type": "dimension" }
  }
}
